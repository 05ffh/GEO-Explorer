# GEO Explorer — Production Environment Template
# Copy to .env.production, fill in real values. NEVER commit .env.production to git.
# Generate random secrets: ./deploy/generate-secrets.sh

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
BASE_URL=https://your-domain.com
ALLOWED_HOSTS=your-domain.com
CORS_ORIGINS=https://your-domain.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=geo
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=geo_explorer
DATABASE_URL=postgresql+asyncpg://geo:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/geo_explorer

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Security ─────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_SECRET
RATE_LIMIT_ENABLED=true
COOKIE_SECURE=true

# ── AI Platforms ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
KIMI_API_KEY=
DOUBAO_API_KEY=
WENXIN_API_KEY=

# ── Search APIs ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ── Feature Flags ────────────────────────────────────────────────────────────
COLLECTION_TEST_MODE=real
GT_SEARCH_TAVILY_ENABLED=true
GT_SEARCH_GOOGLE_CSE_ENABLED=false
GT_SEARCH_BRAVE_ENABLED=false
GT_SEARCH_DUCKDUCKGO_ENABLED=true
