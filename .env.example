# =============================================================================
# GEO Explorer — Environment Variables Template
# Copy to .env or .env.production and fill in real values.
# NEVER commit .env to git — this file only contains placeholder values.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development                            # development | staging | production
SECRET_KEY=change-me-in-production             # 至少 32 字节随机字符串
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://geo:geo@localhost:5432/geo_explorer
TEST_DATABASE_URL=postgresql+asyncpg://geo_test:geo_test@localhost:5433/geo_explorer_test

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI Platforms ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

KIMI_API_KEY=sk-your-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

DOUBAO_API_KEY=your-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-lite-260215

WENXIN_API_KEY=your-key
WENXIN_SECRET_KEY=your-secret
WENXIN_BASE_URL=https://aip.baidubce.com
WENXIN_MODEL=ernie-4.0-turbo-128k

# ── Search ───────────────────────────────────────────────────────────────────
GOOGLE_SEARCH_API_KEY=your-key
GOOGLE_SEARCH_CX=your-cx
BRAVE_SEARCH_API_KEY=your-key

# ── Collector ────────────────────────────────────────────────────────────────
COLLECTOR_CONCURRENCY=4
COLLECTOR_TIMEOUT=30
COLLECTOR_MAX_RETRIES=2

# ── Email (P0) ───────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp                             # smtp | sendgrid | mailgun | ses
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=no-reply@geoexplorer.local
EMAIL_FROM_NAME="GEO Explorer"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASSWORD=your-password

# ── Object Storage (P0) ──────────────────────────────────────────────────────
STORAGE_BACKEND=local                           # local | s3 | minio
S3_BUCKET=geo-explorer-storage
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=https://s3.amazonaws.com       # MinIO: http://minio:9000

# ── HTTPS / Cookie (P0) ──────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000              # production: https://your-domain.com
COOKIE_SECURE=false                             # production: true
COOKIE_DOMAIN=                                  # production: your-domain.com

# ── Rate Limiting (P1) ───────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
REGISTER_RATE_LIMIT_PER_HOUR=5
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ── Feature Toggles ──────────────────────────────────────────────────────────
DEV_ROUTES_ENABLED=true                         # staging: true, production: false
SELF_REGISTRATION_ENABLED=true                  # production: false if invite-only

# ── Monitoring (P1) ──────────────────────────────────────────────────────────
SENTRY_DSN=                                     # production: your-sentry-dsn

# ── System Owner ─────────────────────────────────────────────────────────────
SYSTEM_OWNER_INITIAL_EMAIL=admin@geoexplorer.local
SYSTEM_OWNER_INITIAL_PASSWORD=change-me         # 创建后立即修改
